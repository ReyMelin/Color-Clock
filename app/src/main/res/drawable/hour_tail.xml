<?xml version="1.0" encoding="utf-8"?>
<!-- Hour hand: 200° arc trail on the inner ring (diameter 220, stroke 44).
     The bright end sits at 12 o'clock; the system rotates the drawable. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="450dp"
    android:height="450dp"
    android:viewportWidth="450"
    android:viewportHeight="450">

    <!-- 200° arc from 70° (tail) clockwise to 270° (hand / 12 o'clock) -->
    <path
        android:pathData="M262.62,328.37 A110,110 0 1,1 225,115"
        android:strokeWidth="44"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="sweep"
                android:centerX="225"
                android:centerY="225">
                <!-- 0° – gap region, transparent -->
                <item android:offset="0.000" android:color="#00000000" />
                <!-- ~59° – round cap edge (11° before path start) -->
                <item android:offset="0.161" android:color="#00000000" />
                <!-- 70° – path start, faintest copper -->
                <item android:offset="0.194" android:color="#1AB87333" />
                <!-- ~137° – one-third through visible arc -->
                <item android:offset="0.380" android:color="#66B87333" />
                <!-- ~203° – two-thirds through visible arc -->
                <item android:offset="0.564" android:color="#B3B87333" />
                <!-- ~250° – reach full brightness, start plateau -->
                <item android:offset="0.694" android:color="#FFB87333" />
                <!-- ~281° – past round cap edge at head -->
                <item android:offset="0.781" android:color="#FFB87333" />
                <!-- Drop to transparent after cap -->
                <item android:offset="0.789" android:color="#00000000" />
                <!-- 360° – gap, matches start -->
                <item android:offset="1.000" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Tip circle at 12 o'clock leading edge (diameter = stroke 44) -->
    <path
        android:pathData="M203,115 A22,22 0 1,1 247,115 A22,22 0 1,1 203,115"
        android:fillColor="#FFB87333" />
</vector>
