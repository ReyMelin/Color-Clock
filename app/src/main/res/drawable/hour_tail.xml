<?xml version="1.0" encoding="utf-8"?>
<!-- Hour hand: 200° arc trail on the inner ring (diameter 220, stroke 44).
     The bright end sits at 12 o'clock; the system rotates the drawable. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="450dp"
    android:height="450dp"
    android:viewportWidth="450"
    android:viewportHeight="450">

    <!-- 200° arc from 70° (tail) clockwise to 270° (hand / 12 o'clock) -->
    <path
        android:pathData="M262.62,328.37 A110,110 0 1,1 225,115"
        android:strokeWidth="44"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="sweep"
                android:centerX="225"
                android:centerY="225">
                <!-- 0° – gap region, transparent -->
                <item android:offset="0.000" android:color="#00FFFFFF" />
                <!-- ~59° – round cap edge -->
                <item android:offset="0.161" android:color="#00FFFFFF" />
                <!-- 70° – tail start, barely visible -->
                <item android:offset="0.194" android:color="#0DFFFFFF" />
                <item android:offset="0.257" android:color="#1FFFFFFF" />
                <item android:offset="0.319" android:color="#33FFFFFF" />
                <item android:offset="0.382" android:color="#4DFFFFFF" />
                <item android:offset="0.444" android:color="#6BFFFFFF" />
                <item android:offset="0.507" android:color="#8AFFFFFF" />
                <item android:offset="0.569" android:color="#ABFFFFFF" />
                <item android:offset="0.632" android:color="#CCFFFFFF" />
                <!-- ~250° – full brightness -->
                <item android:offset="0.694" android:color="#FFFFFFFF" />
                <!-- ~281° – past round cap edge at head -->
                <item android:offset="0.781" android:color="#FFFFFFFF" />
                <!-- Drop to transparent after cap -->
                <item android:offset="0.789" android:color="#00FFFFFF" />
                <!-- 360° – gap, matches start -->
                <item android:offset="1.000" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Tip circle at 12 o'clock leading edge (diameter = stroke 44) -->
    <path
        android:pathData="M203,115 A22,22 0 1,1 247,115 A22,22 0 1,1 203,115"
        android:fillColor="#FFFFFFFF" />
</vector>
