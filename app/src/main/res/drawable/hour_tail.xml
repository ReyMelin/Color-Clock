<?xml version="1.0" encoding="utf-8"?>
<!-- Hour hand: 240° arc trail on the inner ring (diameter 220, stroke 44).
     The bright end sits at 12 o'clock; the system rotates the drawable. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="450dp"
    android:height="450dp"
    android:viewportWidth="450"
    android:viewportHeight="450">

    <!-- 240° arc from 30° (tail) clockwise to 270° (hand / 12 o'clock) -->
    <path
        android:pathData="M320.26,280 A110,110 0 1,1 225,115"
        android:strokeWidth="44"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="sweep"
                android:centerX="225"
                android:centerY="225">
                <!-- 0° – gap region, transparent -->
                <item android:offset="0.000" android:color="#00B87333" />
                <!-- Just before tail start -->
                <item android:offset="0.073" android:color="#00B87333" />
                <!-- 30° – tail start, faintest copper -->
                <item android:offset="0.083" android:color="#1AB87333" />
                <!-- ~110° – one-third through visible arc -->
                <item android:offset="0.305" android:color="#66B87333" />
                <!-- ~190° – two-thirds through visible arc -->
                <item android:offset="0.528" android:color="#B3B87333" />
                <!-- ~250° – reach full brightness, start plateau -->
                <item android:offset="0.694" android:color="#FFB87333" />
                <!-- 270° (12 o'clock) – maintain full bright copper -->
                <item android:offset="0.750" android:color="#FFB87333" />
                <!-- Immediately drop to transparent – gap region -->
                <item android:offset="0.760" android:color="#00B87333" />
                <!-- 360° – gap, matches start -->
                <item android:offset="1.000" android:color="#00B87333" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Tip circle at 12 o'clock leading edge -->
    <path
        android:pathData="M215,115 A10,10 0 1,1 235,115 A10,10 0 1,1 215,115"
        android:fillColor="#FFB87333" />
</vector>
