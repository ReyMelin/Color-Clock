<?xml version="1.0" encoding="utf-8"?>
<!-- Minute hand: 200° arc trail on the middle ring (diameter 320, stroke 24).
     The bright end sits at 12 o'clock; the system rotates the drawable. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="450dp"
    android:height="450dp"
    android:viewportWidth="450"
    android:viewportHeight="450">

    <!-- 200° arc from 70° (tail) clockwise to 270° (hand / 12 o'clock) -->
    <path
        android:pathData="M279.72,375.35 A160,160 0 1,1 225,65"
        android:strokeWidth="24"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="sweep"
                android:centerX="225"
                android:centerY="225">
                <!-- 0° – gap region, opaque background -->
                <item android:offset="0.000" android:color="#FF0B1020" />
                <!-- ~66° – round cap edge (4° before path start) -->
                <item android:offset="0.183" android:color="#FF0B1020" />
                <!-- 70° – path start, faintest gold -->
                <item android:offset="0.194" android:color="#1ACFB53B" />
                <!-- ~137° – one-third through visible arc -->
                <item android:offset="0.380" android:color="#66CFB53B" />
                <!-- ~203° – two-thirds through visible arc -->
                <item android:offset="0.564" android:color="#B3CFB53B" />
                <!-- ~250° – reach full brightness, start plateau -->
                <item android:offset="0.694" android:color="#FFCFB53B" />
                <!-- ~274° – past round cap edge at head -->
                <item android:offset="0.762" android:color="#FFCFB53B" />
                <!-- Drop to background after cap -->
                <item android:offset="0.770" android:color="#FF0B1020" />
                <!-- 360° – gap, matches start -->
                <item android:offset="1.000" android:color="#FF0B1020" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Tip circle at 12 o'clock leading edge (diameter = stroke 24) -->
    <path
        android:pathData="M213,65 A12,12 0 1,1 237,65 A12,12 0 1,1 213,65"
        android:fillColor="#FFCFB53B" />
</vector>
