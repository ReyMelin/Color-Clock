<?xml version="1.0" encoding="utf-8"?>
<!-- Second hand: 240° arc trail on the outer ring (diameter 400, stroke 12).
     The bright end sits at 12 o'clock; the system rotates the drawable. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="450dp"
    android:height="450dp"
    android:viewportWidth="450"
    android:viewportHeight="450">

    <!-- 240° arc from 30° (tail) clockwise to 270° (hand / 12 o'clock) -->
    <path
        android:pathData="M398.21,325 A200,200 0 1,1 225,25"
        android:strokeWidth="12"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="sweep"
                android:centerX="225"
                android:centerY="225">
                <!-- 0° – gap region, transparent -->
                <item android:offset="0.000" android:color="#00C0C0C0" />
                <!-- Just before tail start -->
                <item android:offset="0.073" android:color="#00C0C0C0" />
                <!-- 30° – tail start, faintest silver -->
                <item android:offset="0.083" android:color="#1AC0C0C0" />
                <!-- ~110° – one-third through visible arc -->
                <item android:offset="0.305" android:color="#66C0C0C0" />
                <!-- ~190° – two-thirds through visible arc -->
                <item android:offset="0.528" android:color="#B3C0C0C0" />
                <!-- 270° (12 o'clock) – hand position, full bright silver -->
                <item android:offset="0.750" android:color="#FFC0C0C0" />
                <!-- Immediately drop to transparent – gap region -->
                <item android:offset="0.760" android:color="#00C0C0C0" />
                <!-- 360° – gap, matches start -->
                <item android:offset="1.000" android:color="#00C0C0C0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
