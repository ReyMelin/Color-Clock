<?xml version="1.0" encoding="utf-8"?>
<!-- Second hand: 200° arc trail on the outer ring (diameter 400, stroke 12).
     The bright end sits at 12 o'clock; the system rotates the drawable. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="450dp"
    android:height="450dp"
    android:viewportWidth="450"
    android:viewportHeight="450">

    <!-- 200° arc from 70° (tail) clockwise to 270° (hand / 12 o'clock) -->
    <path
        android:pathData="M293.40,412.94 A200,200 0 1,1 225,25"
        android:strokeWidth="12"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="sweep"
                android:centerX="225"
                android:centerY="225">
                <!-- 0° – gap region, transparent -->
                <item android:offset="0.000" android:color="#00FFFFFF" />
                <!-- ~68° – round cap edge -->
                <item android:offset="0.189" android:color="#00FFFFFF" />
                <!-- 70° – tail start, barely visible -->
                <item android:offset="0.194" android:color="#0DFFFFFF" />
                <item android:offset="0.264" android:color="#1FFFFFFF" />
                <item android:offset="0.333" android:color="#33FFFFFF" />
                <item android:offset="0.403" android:color="#4DFFFFFF" />
                <item android:offset="0.472" android:color="#6BFFFFFF" />
                <item android:offset="0.542" android:color="#8AFFFFFF" />
                <item android:offset="0.611" android:color="#ABFFFFFF" />
                <item android:offset="0.681" android:color="#CCFFFFFF" />
                <!-- 270° – full brightness -->
                <item android:offset="0.750" android:color="#FFFFFFFF" />
                <!-- ~272° – past round cap edge at head -->
                <item android:offset="0.755" android:color="#FFFFFFFF" />
                <!-- Drop to transparent after cap -->
                <item android:offset="0.761" android:color="#00FFFFFF" />
                <!-- 360° – gap, matches start -->
                <item android:offset="1.000" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
