<?xml version="1.0" encoding="utf-8"?>
<!-- Second hand: 200° arc trail on the outer ring (diameter 400, stroke 12).
     The bright end sits at 12 o'clock; the system rotates the drawable. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="450dp"
    android:height="450dp"
    android:viewportWidth="450"
    android:viewportHeight="450">

    <!-- 200° arc from 70° (tail) clockwise to 270° (hand / 12 o'clock) -->
    <path
        android:pathData="M293.40,412.94 A200,200 0 1,1 225,25"
        android:strokeWidth="12"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="sweep"
                android:centerX="225"
                android:centerY="225">
                <!-- 0° – gap region, transparent -->
                <item android:offset="0.000" android:color="#000B1020" />
                <!-- ~68° – round cap edge (2° before path start) -->
                <item android:offset="0.189" android:color="#000B1020" />
                <!-- 70° – path start, faintest silver -->
                <item android:offset="0.194" android:color="#1AC0C0C0" />
                <!-- ~137° – one-third through visible arc -->
                <item android:offset="0.380" android:color="#66C0C0C0" />
                <!-- ~203° – two-thirds through visible arc -->
                <item android:offset="0.564" android:color="#B3C0C0C0" />
                <!-- 270° (12 o'clock) – full bright silver -->
                <item android:offset="0.750" android:color="#FFC0C0C0" />
                <!-- ~272° – past round cap edge at head -->
                <item android:offset="0.755" android:color="#FFC0C0C0" />
                <!-- Drop to transparent after cap -->
                <item android:offset="0.761" android:color="#000B1020" />
                <!-- 360° – gap, matches start -->
                <item android:offset="1.000" android:color="#000B1020" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
