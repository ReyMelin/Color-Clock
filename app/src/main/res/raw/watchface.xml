<?xml version="1.0" encoding="utf-8"?>
<WatchFace width="450" height="450">

    <Metadata key="CLOCK_TYPE" value="ANALOG" />
    <Metadata key="PREVIEW_TIME" value="10:08:32" />

    <Scene backgroundColor="#FF0B1020">

        <!-- Background -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Ellipse x="0" y="0" width="450" height="450">
                <Fill color="#FF0B1020" />
            </Ellipse>
        </PartDraw>

        <!-- Rotating hands -->
        <AnalogClock x="0" y="0" width="450" height="450">

            <HourHand
                resource="@drawable/hour_tail"
                x="0"
                y="0"
                width="450"
                height="450"
                pivotX="0.5"
                pivotY="0.5" />

            <MinuteHand
                resource="@drawable/minute_tail"
                x="0"
                y="0"
                width="450"
                height="450"
                pivotX="0.5"
                pivotY="0.5" />

            <SecondHand
                resource="@drawable/second_tail"
                x="0"
                y="0"
                width="450"
                height="450"
                pivotX="0.5"
                pivotY="0.5">
                <Sweep frequency="30" />
            </SecondHand>

        </AnalogClock>

        <!-- Center cap -->
        <PartDraw x="219" y="219" width="12" height="12">
            <Ellipse x="0" y="0" width="12" height="12">
                <Fill color="#FF0B1020" />
            </Ellipse>
        </PartDraw>

        <!-- AM/PM center indicator: semicircle arc around center cap -->
        <Condition>
            <Expressions>
                <Expression name="isAM"><![CDATA[[HOUR_0_23] < 12]]></Expression>
            </Expressions>

            <Compare expression="isAM">
                <PartDraw x="0" y="0" width="450" height="450">
                    <!-- AM: left bright, right dim -->
                    <Arc centerX="225" centerY="225" width="30" height="30"
                         startAngle="180" endAngle="360" direction="CLOCKWISE">
                        <Stroke color="#18C0C0C0" thickness="5" cap="ROUND" />
                    </Arc>
                    <Arc centerX="225" centerY="225" width="30" height="30"
                         startAngle="0" endAngle="180" direction="CLOCKWISE">
                        <Stroke color="#66C0C0C0" thickness="5" cap="ROUND" />
                    </Arc>
                </PartDraw>
            </Compare>

            <Default>
                <PartDraw x="0" y="0" width="450" height="450">
                    <!-- PM: left dim, right bright -->
                    <Arc centerX="225" centerY="225" width="30" height="30"
                         startAngle="180" endAngle="360" direction="CLOCKWISE">
                        <Stroke color="#66C0C0C0" thickness="5" cap="ROUND" />
                    </Arc>
                    <Arc centerX="225" centerY="225" width="30" height="30"
                         startAngle="0" endAngle="180" direction="CLOCKWISE">
                        <Stroke color="#18C0C0C0" thickness="5" cap="ROUND" />
                    </Arc>
                </PartDraw>
            </Default>
        </Condition>

    </Scene>
</WatchFace>