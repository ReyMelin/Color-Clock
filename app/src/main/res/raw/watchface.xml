<?xml version="1.0" encoding="utf-8"?>
<WatchFace width="450" height="450">

    <Metadata key="CLOCK_TYPE" value="ANALOG" />
    <Metadata key="PREVIEW_TIME" value="10:08:32" />

    <Scene backgroundColor="#FF0B1020">

        <!-- Background -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Ellipse x="0" y="0" width="450" height="450">
                <Fill color="#FF0B1020" />
            </Ellipse>
        </PartDraw>

        <!-- Ghost hour ring -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Arc
                centerX="225"
                centerY="225"
                width="300"
                height="300"
                startAngle="0"
                endAngle="360"
                direction="CLOCKWISE">
                <Stroke color="#221A0F08" thickness="150" />
            </Arc>
        </PartDraw>

        <!-- Ghost minute ring -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Arc
                centerX="225"
                centerY="225"
                width="392"
                height="392"
                startAngle="0"
                endAngle="360"
                direction="CLOCKWISE">
                <Stroke color="#22342E0A" thickness="60" />
            </Arc>
        </PartDraw>

        <!-- Ghost second ring -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Arc
                centerX="225"
                centerY="225"
                width="440"
                height="440"
                startAngle="0"
                endAngle="360"
                direction="CLOCKWISE">
                <Stroke color="#22383838" thickness="18" />
            </Arc>
        </PartDraw>

        <!-- Rotating hands -->
        <AnalogClock x="0" y="0" width="450" height="450">

            <HourHand
                resource="@drawable/hour_tail"
                x="0"
                y="0"
                width="450"
                height="450"
                pivotX="225"
                pivotY="225" />

            <MinuteHand
                resource="@drawable/minute_tail"
                x="0"
                y="0"
                width="450"
                height="450"
                pivotX="225"
                pivotY="225" />

            <SecondHand
                resource="@drawable/second_tail"
                x="0"
                y="0"
                width="450"
                height="450"
                pivotX="225"
                pivotY="225" />

        </AnalogClock>

        <!-- Center cap -->
        <PartDraw x="213" y="213" width="24" height="24">
            <Ellipse x="0" y="0" width="24" height="24">
                <Fill color="#FF0B1020" />
            </Ellipse>
        </PartDraw>

    </Scene>
</WatchFace>