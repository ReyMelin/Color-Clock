<?xml version="1.0" encoding="utf-8"?>
<WatchFace width="450" height="450">

    <Metadata key="CLOCK_TYPE" value="ANALOG" />
    <Metadata key="PREVIEW_TIME" value="10:08:32" />

    <Scene backgroundColor="#FF0B1020">

        <!-- Background -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Ellipse x="0" y="0" width="450" height="450">
                <Fill color="#FF0B1020" />
            </Ellipse>
        </PartDraw>

        <!-- Ghost hour ring -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Arc
                centerX="225"
                centerY="225"
                width="220"
                height="220"
                startAngle="0"
                endAngle="360"
                direction="CLOCKWISE">
                <Stroke color="#221A0F08" thickness="44" />
            </Arc>
        </PartDraw>

        <!-- Ghost minute ring -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Arc
                centerX="225"
                centerY="225"
                width="320"
                height="320"
                startAngle="0"
                endAngle="360"
                direction="CLOCKWISE">
                <Stroke color="#22342E0A" thickness="24" />
            </Arc>
        </PartDraw>

        <!-- Ghost second ring -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Arc
                centerX="225"
                centerY="225"
                width="400"
                height="400"
                startAngle="0"
                endAngle="360"
                direction="CLOCKWISE">
                <Stroke color="#22383838" thickness="12" />
            </Arc>
        </PartDraw>

        <!-- Rotating hands -->
        <AnalogClock x="0" y="0" width="450" height="450">

            <HourHand
                resource="@drawable/hour_tail"
                x="0"
                y="0"
                width="450"
                height="450"
                pivotX="0.5"
                pivotY="0.5" />

            <MinuteHand
                resource="@drawable/minute_tail"
                x="0"
                y="0"
                width="450"
                height="450"
                pivotX="0.5"
                pivotY="0.5" />

            <SecondHand
                resource="@drawable/second_tail"
                x="0"
                y="0"
                width="450"
                height="450"
                pivotX="0.5"
                pivotY="0.5">
                <Sweep frequency="30" />
            </SecondHand>

        </AnalogClock>

        <!-- Center cap -->
        <PartDraw x="219" y="219" width="12" height="12">
            <Ellipse x="0" y="0" width="12" height="12">
                <Fill color="#FF0B1020" />
            </Ellipse>
        </PartDraw>

        <!-- AM/PM center indicator: semicircle arc around center cap -->
        <Condition>
            <Expressions>
                <Expression name="isAM"><![CDATA[[HOUR_0_23] < 12]]></Expression>
            </Expressions>

            <Compare expression="isAM">
                <!-- AM -->
                <PartDraw x="0" y="0" width="450" height="450">
                    <Arc
                        centerX="225"
                        centerY="225"
                        width="26"
                        height="26"
                        startAngle="180"
                        endAngle="360"
                        direction="CLOCKWISE">
                        <Stroke color="#66C0C0C0" thickness="6" cap="ROUND" />
                    </Arc>
                </PartDraw>
            </Compare>

            <Default>
                <!-- PM -->
                <PartDraw x="0" y="0" width="450" height="450">
                    <Arc
                        centerX="225"
                        centerY="225"
                        width="26"
                        height="26"
                        startAngle="0"
                        endAngle="180"
                        direction="CLOCKWISE">
                        <Stroke color="#66C0C0C0" thickness="6" cap="ROUND" />
                    </Arc>
                </PartDraw>
            </Default>
        </Condition>

    </Scene>
</WatchFace>